{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Run WhoSingsThis (Linux)",
            "type": "shell",
            "command": "flutter run -d linux",
            "options": {
                "cwd": "${workspaceFolder}/client"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "📦 Build Linux Release",
            "type": "shell",
            "command": "flutter build linux",
            "options": {
                "cwd": "${workspaceFolder}/client"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "📱 Build Android APK",
            "type": "shell",
            "command": "flutter build apk --debug",
            "options": {
                "cwd": "${workspaceFolder}/client"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "🌐 Launch Web Preview",
            "type": "shell",
            "command": "npx serve -l 8000 .",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "🧹 Project: Reset (Clean & Fetch)",
            "type": "shell",
            "command": "cd client && flutter clean && flutter pub get",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Server",
            "type": "shell",
            "command": "dart bin/server.dart",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}
